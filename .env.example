# sync-pipeline.mjs (yarn sync:pipeline)
# Copy to .env and fill in values. The script loads .env from the repo root.

# Required: path to deployment JSON (relative to repo root or absolute).
# See deployments/example-arbitrum-sepolia.json for shape (addresses, startBlock / startBlocks.*).
DEPLOY_JSON=./deployments/example-arbitrum-sepolia.json

# Goldsky subgraph name used for list/deploy/tag (default: biribi).
GOLDSKY_SUBGRAPH_NAME=biribi

# Set to 1 to only patch turbo.yaml / subgraph.yaml and exit (no goldsky CLI, codegen, deploy).
GOLDSKY_SYNC_FILES_ONLY=0

# Required for full sync when turbo.yaml contains ${WEBHOOK_SECRET} (pipeline URL / webhook).
# Omit or leave empty if you use GOLDSKY_SYNC_FILES_ONLY=1 or your turbo template has no placeholder.
WEBHOOK_SECRET=

# Optional Goldsky deploy behavior (uncomment and set when needed):
# GOLDSKY_SUBGRAPH_AUTO_PRUNE=0
# GOLDSKY_SKIP_PROD_REPOINT_FOR_PRUNE=1
# GOLDSKY_SKIP_PROD_TAG=1
