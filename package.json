{
  "name": "subgraph",
  "version": "0.1.14",
  "type": "module",
  "private": true,
  "scripts": {
    "codegen": "graph codegen",
    "build": "graph build",
    "test": "graph test",
    "sync:pipeline": "node scripts/sync-pipeline.mjs",
    "deploy:subgraph": "yarn goldsky subgraph deploy biribi/\"$@\"",
    "prod:subgraph": "yarn goldsky subgraph tag create biribi/\"$@\" --tag prod",
    "deploy": "yarn codegen && yarn build && yarn deploy:subgraph $@ && yarn prod:subgraph $@",
    "deploy:api": "yarn codegen && yarn build && node scripts/goldsky-deploy.mjs"
  },
  "devDependencies": {
    "@goldskycom/cli": "^13.3.3",
    "@graphprotocol/graph-cli": "^0.97.1",
    "@graphprotocol/graph-ts": "^0.38.1",
    "dotenv": "^16.5.0",
    "semver": "^7.7.2"
  },
  "packageManager": "yarn@4.9.2+sha512.1fc009bc09d13cfd0e19efa44cbfc2b9cf6ca61482725eb35bbc5e257e093ebf4130db6dfe15d604ff4b79efd8e1e8e99b25fa7d0a6197c9f9826358d4d65c3c",
  "dependencies": {
    "matchstick-as": "^0.6.0"
  }
}
